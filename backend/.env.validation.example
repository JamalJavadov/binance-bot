# =====================================================================
# AQRR VALIDATION ENVIRONMENT TEMPLATE
# =====================================================================
# DO NOT merge these settings into your live trading `.env`.
# This file governs the offline walk-forward evaluation pipeline.
#
# Load this environment exclusively when running offline validations:
#   export $(cat backend/.env.validation.example | xargs)
#   python backend/scripts/walkforward_import_test.py ...

# 1. Validation Database (Safety Bound)
# The database name MUST contain the word 'validation' or 'test'. 
# The offline import scripts will refuse to execute against any DB without this.
DATABASE_URL=postgresql+asyncpg://futuresbot:futuresbot@localhost:5432/aqrr_validation_db

# 2. Paper Trading Simulation (Optional Future Bound)
# If adapting the runtime for paper execution, ensure you target the testnet.
BINANCE_BASE_URL=https://testnet.binancefuture.com
